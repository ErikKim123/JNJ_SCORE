# Google Apps Script Web App URL (deploy → Web app → URL)
NEXT_PUBLIC_APPS_SCRIPT_URL=https://script.google.com/macros/s/REPLACE_ME/exec

# Shared token for POST validation. Set the same value in Apps Script Properties.
# Rotate per competition. Note: client-side bundled — see Design §10 for threat model.
NEXT_PUBLIC_APPS_SCRIPT_TOKEN=REPLACE_ME
